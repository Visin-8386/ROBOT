    MOTOR -->|"robot/alert"| MOSQUITTO
    MOSQUITTO -->|"robot/alert"| MQTT_S
    MQTT_S -->|"save alerts"| DB
    YOLO -->|"save events<br/>+ screenshots"| DB
    YOLO -->|"detection alert"| TELE
    API -->|"REST API"| WEB
    API -->|"REST API"| FLUTTER
    API -->|"command_queue"| MQTT_S
    API <-->|"query/write"| DB
    CAM -.->|"MJPEG Stream"| WEB

    style CAM fill:#f59e0b,color:#000
    style MOTOR fill:#f59e0b,color:#000
    style YOLO fill:#8b5cf6,color:#fff
    style MOSQUITTO fill:#10b981,color:#fff
